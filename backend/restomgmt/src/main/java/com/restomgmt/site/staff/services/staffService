package com.restomgmt.site.staff.services;

import com.restomgmt.site.client.models.Client;
import com.restomgmt.sit.client.repositories.clientRepo;

import org.spirngframework.*;

import java.util.*;

@Service
public class clientService {
    @Autowired
    private clientRepo clientRepo;

    public Staff addStaff (Staff staff) {
        return staffRepo.save(staff);
    }

    public List<Staff> getAllStaff() {
        return staffRepo.findAll();
    }

    public Optional<Client> findStaffById(Long id) {
        return Optional.ofNullable(staffRepo.getById(id));
    }

    public void deleteStaff(Staff staff) {
        staffRepo.delete(staff);
    }

    public void updateStaff(Staff staff) {
        staffRepo.save(staff);
    }
}